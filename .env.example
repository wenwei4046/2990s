SUPABASE_URL=https://dolvxrchzbnqvahocwsu.supabase.co

# Vite-exposed copies (VITE_ prefix → bundled into browser code).
# NEVER add VITE_SUPABASE_SERVICE_ROLE_KEY — service_role is server-only.
VITE_SUPABASE_URL=https://dolvxrchzbnqvahocwsu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx

# Publishable key (recommended for client-side; sb_publishable_*)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxx

# Legacy anon key (fallback for libraries pretrained on JWT format)
SUPABASE_ANON_KEY=eyJxxxx...

# Service role key — DASHBOARD ONLY (Supabase Dashboard → Settings → API → service_role)
# Used by API server (Hono on Workers) for RLS bypass.
# NEVER ship to client. NEVER commit.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...

# Direct Postgres connection (for Drizzle migrations, server-side queries)
# Format: postgresql://postgres.{ref}:{password}@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# Get from Dashboard → Project Settings → Database → Connection string → URI (Transaction mode)
DATABASE_URL=postgresql://postgres.dolvxrchzbnqvahocwsu:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# OWNER bootstrap (read by app_config seed; auth.users INSERT trigger compares against this)
# See PORT_DESIGN.md §11.1 Issue 1 (Codex P1.8 fold).
OWNER_EMAIL=wenwei4046@gmail.com

