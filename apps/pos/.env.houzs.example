# ---------------------------------------------------------------------------
# POS staging/cutover env — HOUZS target (P5).
#
# Copy to `.env.houzs` for a local staging build (`vite build --mode houzs`),
# OR set these as the environment variables on the CF Pages STAGING project.
# The `VITE_BACKEND_TARGET=houzs` flip is what routes every read/auth to Houzs
# (this build 404s against 2990 — it is the cutover build, not deployable to
# the current 2990 prod).
#
# Placeholders below are marked <FILL>. Do NOT commit a real `.env.houzs`.
# ---------------------------------------------------------------------------

# The switch. 'houzs' = read/auth against Houzs. Unset/anything-else = 2990.
VITE_BACKEND_TARGET=houzs

# Houzs SCM API base — the /api/scm sub-app the POS reads (mfg-products,
# maintenance-config, pos-pools, mfg-sales-orders, etc.). Include /api/scm.
# e.g. https://api.houzscentury.com/api/scm
VITE_HOUZS_API_URL=<FILL: https://<houzs-api-host>/api/scm>

# OPTIONAL. The Houzs /api ROOT for the PRE-AUTH routes /api/pos + /api/auth
# (pin-login, sales-staff, email login) which sit OUTSIDE /api/scm. If unset,
# the code derives it by stripping a trailing /scm from VITE_HOUZS_API_URL —
# set this only if your deploy's /api root is NOT that. e.g. https://api.houzscentury.com/api
# VITE_HOUZS_POS_URL=<FILL only if the /scm-stripped derivation is wrong>

# The 2990-mirrored company on Houzs. companies.id = 2 (default). Sent as
# X-Company-Id on every Houzs request so the POS reads company-2 catalogue.
VITE_HOUZS_COMPANY_ID=2

# The showroom this POS instance belongs to (staff picker + order scoping).
# VERIFY: on houzs this must be a HOUZS showroom id, not the 2990 one.
VITE_POS_SHOWROOM_ID=<FILL: houzs showroom id, or leave unset for all>

# ---- still required even on the houzs target (dual-mode) --------------------
# lib/supabase.ts constructs the Supabase client at import time and THROWS if
# these are unset, even though the houzs path never uses it. Set them to the
# existing 2990 values (or any valid-shaped dummy) so the build boots.
VITE_SUPABASE_URL=<FILL: the 2990 Supabase URL, unused on houzs>
VITE_SUPABASE_PUBLISHABLE_KEY=<FILL: the 2990 anon/publishable key, unused on houzs>

# 2990 API base — unused on the houzs path (apiClient uses VITE_HOUZS_API_URL),
# but keep set so any stray direct reference resolves.
VITE_API_URL=<FILL: the 2990 API base, unused on houzs>

# OPTIONAL passthroughs (leave as-is / unset unless you already use them):
# VITE_BACKEND_PORTAL_URL — the old 2990 backend portal (Catalog "Create SO"
#   emergency link). 2990-only; 404s gracefully on houzs. Leave unset.
# VITE_HANDOVER_MODE — existing handover-flow toggle; unchanged by the cutover.
